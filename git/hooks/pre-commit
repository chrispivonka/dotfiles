#!/usr/bin/env bash
# Global pre-commit hook (core.hooksPath) — applies to every repo on this machine.
# Bypass with `git commit --no-verify` when a check is a false positive.
set -euo pipefail

# Block secrets in staged changes
if command -v gitleaks &>/dev/null; then
    gitleaks protect --staged --redact -v
fi

# Block accidentally-staged large files (e.g. datasets, binaries, media)
max_kb=5120
while IFS= read -r -d '' file; do
    [ -f "$file" ] || continue
    size_kb=$(( $(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null) / 1024 ))
    if [ "$size_kb" -gt "$max_kb" ]; then
        echo "error: $file is ${size_kb}KB, over the ${max_kb}KB limit (git commit --no-verify to bypass)" >&2
        exit 1
    fi
done < <(git diff --cached --name-only --diff-filter=ACM -z)

# Block files that are almost always credentials/keys, even if their content
# doesn't trip gitleaks (e.g. an empty placeholder .env)
sensitive_pattern='(^|/)(\.env(\..+)?|.*\.pem|.*\.key|id_rsa|id_ed25519|id_ecdsa)$'
while IFS= read -r -d '' file; do
    if [[ "$file" =~ $sensitive_pattern ]]; then
        echo "error: '$file' looks like a credential/key file (git commit --no-verify to bypass)" >&2
        exit 1
    fi
done < <(git diff --cached --name-only --diff-filter=ACM -z)

# Block unresolved merge-conflict markers
if git diff --cached -U0 | grep -qE '^\+(<{7}|={7}|>{7})( |$)'; then
    echo "error: staged changes contain unresolved merge-conflict markers (git commit --no-verify to bypass)" >&2
    exit 1
fi

# Block whitespace errors (trailing whitespace, space-before-tab, etc.)
if git rev-parse --verify HEAD >/dev/null 2>&1; then
    against=HEAD
else
    against=$(git hash-object -t tree /dev/null)
fi
if ! git diff-index --check --cached "$against" --; then
    echo "error: whitespace issues detected above (git commit --no-verify to bypass)" >&2
    exit 1
fi
