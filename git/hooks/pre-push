#!/usr/bin/env bash
# Global pre-push hook (core.hooksPath) — applies to every repo on this machine.
# 1. Blocks force-pushes that rewrite main/master history.
# 2. Scans outgoing commits for secrets, catching anything that slipped through
#    if pre-commit was ever bypassed with --no-verify.
# Bypass with `git push --no-verify` when a check is a false positive.
set -euo pipefail

zero="0000000000000000000000000000000000000000"
status=0

while read -r local_ref local_sha remote_ref remote_sha; do
    [ "$local_sha" = "$zero" ] && continue  # branch deletion, nothing to scan

    # Block history-rewriting pushes to main/master
    case "$remote_ref" in
        refs/heads/main|refs/heads/master)
            if [ "$remote_sha" != "$zero" ] && ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
                echo "error: refusing to force-push over ${remote_ref#refs/heads/} (git push --no-verify to bypass)" >&2
                status=1
                continue
            fi
            ;;
    esac

    command -v gitleaks &>/dev/null || continue

    if [ "$remote_sha" = "$zero" ]; then
        log_opts="$local_sha"  # new branch, no remote history to diff against
    else
        log_opts="${remote_sha}..${local_sha}"
    fi

    gitleaks detect --no-banner --redact --log-opts="$log_opts" -v || status=1
done

exit $status
