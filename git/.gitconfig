# =============================================================================
# .gitconfig — shared git configuration (no personal info)
# Personal settings (name, email, signing key) go in ~/.gitconfig.local
# =============================================================================

[include]
    path = ~/.gitconfig.local

[core]
    editor = nvim
    autocrlf = input
    excludesfile = ~/.gitignore_global
    pager = delta
    whitespace = fix

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true
    followTags = true

[fetch]
    prune = true
    pruneTags = true

[rebase]
    autoStash = true
    autoSquash = true

[merge]
    conflictStyle = zdiff3
    tool = nvim

[diff]
    algorithm = histogram
    colorMoved = default
    renames = copies

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Dracula

[rerere]
    enabled = true

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = -version:refname

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    unstage = reset HEAD --
    discard = checkout --
    last = log -1 HEAD
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    wip = "!git add -A && git commit -m 'WIP [skip ci]'"
    undo = reset --soft HEAD~1
    amend = commit --amend --no-edit
    contributors = shortlog -sn --no-merges
    branches = branch --sort=-committerdate --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(contents:subject) %(color:green)(%(committerdate:relative)) [%(authorname)]'
    cleanup = "!git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d"
    aliases = config --get-regexp ^alias\\.
