#!/usr/bin/env bash
# Resolves 1Password's SSH-signing helper across macOS and Linux so
# git/.gitconfig's gpg.ssh.program can reference a stable, portable name
# instead of a platform-specific absolute path.
set -euo pipefail

candidates=(
    "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"  # macOS
    "/opt/1Password/op-ssh-sign"                               # Linux (deb/rpm package)
    "/usr/lib/1password/op-ssh-sign"                            # Linux (some distros)
)

for path in "${candidates[@]}"; do
    if [ -x "$path" ]; then
        exec "$path" "$@"
    fi
done

echo "op-ssh-sign: not found — is the 1Password desktop app installed?" >&2
exit 1
